{
  "name": "@fssstack/mdkit-backend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "rm -rf dist && tsc --project tsconfig.build.json",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint ."
  },
  "dependencies": {
    "@fastify/cors": "10.0.1",
    "@fssstack/mdkit-server": "workspace:*",
    "@fssstack/mdkit-trpc": "workspace:*",
    "@trpc/server": "11.7.1",
    "fastify": "5.1.0",
    "pino-pretty": "13.1.3",
    "tsx": "4.20.6",
    "zod": "4.1.11"
  }
}
