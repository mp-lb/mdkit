{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "customConditions": ["source"],
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "types": ["node", "vitest"]
  },
  "include": ["src"]
}
